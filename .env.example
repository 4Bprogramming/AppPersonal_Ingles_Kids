# Railway / local
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway auto-inyecta DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/treasure_hunter

# Google OAuth — verificar ID tokens del SDK móvil
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# IA — SDK oficial @google/generative-ai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash

# Admin PIN local (capa extra en app; auth real = Google + family_id)
ADMIN_PIN=1234

# CORS — URL de Expo en dev
CORS_ORIGIN=*
